{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanSpec",
  "type": "object",
  "required": ["stories", "levels"],
  "additionalProperties": false,
  "properties": {
    "stories": { "type": "integer", "enum": [1, 2] },
    "totalAreaSqFt": { "type": "number" },
    "levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "width", "height", "rooms", "doors", "windows"],
        "properties": {
          "level": { "type": "integer" },
          "width": { "type": "number", "minimum": 20, "maximum": 150 },
          "height": { "type": "number", "minimum": 20, "maximum": 150 },
          "rooms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "x", "y", "w", "h"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "label": { "type": "string" },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "w": { "type": "number" },
                "h": { "type": "number" }
              }
            }
          },
          "doors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y", "dir"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "dir": { "type": "string", "enum": ["horizontal", "vertical"] }
              }
            }
          },
          "windows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["x", "y", "dir"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "dir": { "type": "string", "enum": ["horizontal", "vertical"] }
              }
            }
          }
        }
      }
    }
  }
}