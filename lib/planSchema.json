{
  
  "title": "PlanSpec",
  "type": "object",
  "required": ["stories", "levels"],
  "additionalProperties": false,
  "properties": {
    "stories": { "type": "integer", "enum": [1, 2] },
    "totalAreaSqFt": { "type": "number" },
    "levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "width", "height", "rooms", "doors", "windows"],
        "properties": {
          "level": { "type": "integer" },
          "width": { "type": "number", "description": "Width of the level in FEET" },
          "height": { "type": "number", "description": "Height of the level in FEET" },
          "rooms": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type", "x", "y", "w", "h"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "label": { "type": "string" },
                "x": { "type": "number", "description": "X coordinate in FEET" },
                "y": { "type": "number", "description": "Y coordinate in FEET" },
                "w": { "type": "number", "description": "Room width in FEET" },
                "h": { "type": "number", "description": "Room height in FEET" }
              }
            }
          },
          "doors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "x": { "type": "number" }, "y": { "type": "number" }, "dir": { "type": "string" } }
            }
          },
          "windows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "x": { "type": "number" }, "y": { "type": "number" }, "dir": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}